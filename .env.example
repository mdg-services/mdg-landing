# ── Email (dealer enrolment) — SMTP ──────────────────────────────────────
# Provider-agnostic SMTP. Defaults target Hostinger email.
#
# To get these for a Hostinger mailbox (e.g. noreply@mdgservices.in):
#   1. hPanel → Emails → Email Accounts (for the mdgservices.in domain).
#   2. Create the mailbox "noreply@mdgservices.in" and set a password
#      (or "Change password" on an existing one).
#   3. SMTP_USER is the full address; SMTP_PASS is that mailbox password.
#      (Hostinger has no separate "app password" — it's the mailbox password.)

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465            # 465 = SSL (SMTP_SECURE=true). Use 587 + SMTP_SECURE=false for STARTTLS.
SMTP_SECURE=true
SMTP_USER=noreply@mdgservices.in
SMTP_PASS=your-mailbox-password

# "From" header. Defaults to SMTP_USER; name is cosmetic.
MAIL_FROM=noreply@mdgservices.in
MAIL_FROM_NAME=MDG Services

# Where internal enrolment notifications land.
ENROLLMENT_NOTIFY_TO=mdgservicesterms@gmail.com

# Notes:
# - Set these in Vercel → Project → Settings → Environment Variables for prod.
# - Locally, copy this file to `.env` (or `.env.local`). Without credentials the
#   dev server logs emails to the terminal instead of sending, so the form
#   still works for testing.
