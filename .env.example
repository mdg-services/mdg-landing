# ── Email (dealer enrolment) ─────────────────────────────────────────────
# Gmail account used to SEND mail, plus a Google "App Password" (NOT the
# account password). Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification on the account).
GMAIL_USER=mdgservicesterms@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Where internal enrolment notifications land (defaults to the address below).
ENROLLMENT_NOTIFY_TO=mdgservicesterms@gmail.com

# Display name on the "From" header (optional).
MAIL_FROM_NAME=MDG Services

# Notes:
# - Set these in Vercel → Project → Settings → Environment Variables for prod.
# - Locally, copy this file to `.env` (or `.env.local`). Without credentials the
#   dev server logs emails to the terminal instead of sending them, so the form
#   still works for testing.
